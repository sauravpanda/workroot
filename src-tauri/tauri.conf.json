{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/.nicegui/schema/tauri-conf.json",
  "productName": "Workroot",
  "version": "0.1.10",
  "identifier": "com.workroot.dev",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Workroot",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2024-2026 Saurav Panda. All rights reserved.",
    "shortDescription": "A local-first developer workspace for managing projects, terminals, and Git workflows.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {}
    },
    "linux": {
      "deb": {},
      "rpm": {}
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4Rjk4MkVCQkUwNzZBRjIKUldUeWFnZSs2NEw1bUd5NnpZbldnUGVWOGNHY3hIdGFKbXl4eWtBcWt6LzBZYmduNW9vUWpwSVIK",
      "endpoints": [
        "https://github.com/sauravpanda/workroot/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installerArgs": []
      }
    }
  }
}
